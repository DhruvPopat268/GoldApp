{
  "info": {
    "name": "Gold Loan Management API",
    "_postman_id": "gold-loan-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://gold-app.onrender.com" },
    { "key": "token", "value": "" },
    { "key": "bank_id", "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "loan_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/signup", "host": ["{{base_url}}"], "path": ["api", "auth", "signup"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Banks",
      "item": [
        {
          "name": "Create Bank",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res._id) pm.collectionVariables.set('bank_id', res._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "State Bank of India", "type": "text" },
                { "key": "logo", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{base_url}}/api/banks", "host": ["{{base_url}}"], "path": ["api", "banks"] }
          }
        },
        {
          "name": "Get All Banks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/banks", "host": ["{{base_url}}"], "path": ["api", "banks"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res._id) pm.collectionVariables.set('category_id', res._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"name\": \"Necklace\" }"
            },
            "url": { "raw": "{{base_url}}/api/categories", "host": ["{{base_url}}"], "path": ["api", "categories"] }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/categories", "host": ["{{base_url}}"], "path": ["api", "categories"] }
          }
        }
      ]
    },
    {
      "name": "Loans",
      "item": [
        {
          "name": "Create Loan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res._id) pm.collectionVariables.set('loan_id', res._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "bank_id", "value": "{{bank_id}}", "type": "text" },
                { "key": "full_name", "value": "Ramesh Kumar", "type": "text" },
                { "key": "dob", "value": "1985-06-15", "type": "text" },
                { "key": "mobile", "value": "9876543210", "type": "text" },
                { "key": "address", "value": "123 Main Street, Chennai, Tamil Nadu", "type": "text" },
                { "key": "account_number", "value": "SBI0012345678", "type": "text" },
                { "key": "nominee_name", "value": "Suresh Kumar", "type": "text" },
                { "key": "nominee_dob", "value": "2005-03-20", "type": "text" },
                {
                  "key": "items",
                  "value": "[{\"category_id\":\"{{category_id}}\",\"gross_weight\":12.5,\"net_weight\":11.8,\"carat\":22,\"rate_per_gram\":5800},{\"category_id\":\"{{category_id}}\",\"gross_weight\":8.0,\"net_weight\":7.5,\"carat\":18,\"rate_per_gram\":4800}]",
                  "type": "text"
                },
                { "key": "item_image_0", "type": "file", "src": [] },
                { "key": "item_image_1", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{base_url}}/api/loans", "host": ["{{base_url}}"], "path": ["api", "loans"] }
          }
        },
        {
          "name": "Get All Loans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/loans", "host": ["{{base_url}}"], "path": ["api", "loans"] }
          }
        },
        {
          "name": "Get Loan By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/loans/{{loan_id}}", "host": ["{{base_url}}"], "path": ["api", "loans", "{{loan_id}}"] }
          }
        },
        {
          "name": "Delete Loan",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/loans/{{loan_id}}", "host": ["{{base_url}}"], "path": ["api", "loans", "{{loan_id}}"] }
          }
        }
      ]
    }
  ]
}
